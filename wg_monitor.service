[Unit]
Description=WireGuard Monitor
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
#Environment=WG_MONITOR_CONFIG_DIR=/etc/wg_monitor
ExecStart=/usr/local/bin/wg_monitor --disable-timestamps --verbose
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
